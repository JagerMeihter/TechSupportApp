<Window x:Class="TechSupportApp.Views.StatusChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение статуса" Height="150" Width="300" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <Label Content="Выберите новый статус:"/>
        <ComboBox Name="StatusCombo" ItemsSource="{Binding Statuses}" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        <Button Content="Сохранить" Click="SaveButton_Click" Margin="5" Width="80" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>