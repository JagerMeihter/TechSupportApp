<Window x:Class="TechSupportApp.Views.RequestEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заявки" Height="500" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Клиент:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding ClientName}"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Телефон:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding ClientPhone}"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Тип техники:"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="5" ItemsSource="{Binding EquipmentTypes}"
                  DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding EquipmentTypeId}"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Описание:"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="5" Text="{Binding Description}" TextWrapping="Wrap"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Приоритет:"/>
        <ComboBox Grid.Row="4" Grid.Column="1" Margin="5" ItemsSource="{Binding Priorities}"
                  DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding PriorityId}"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Статус:"/>
        <ComboBox Grid.Row="5" Grid.Column="1" Margin="5" ItemsSource="{Binding Statuses}"
                  DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding StatusId}"/>

        <Label Grid.Row="6" Grid.Column="0" Content="Исполнитель:"/>
        <ComboBox Grid.Row="6" Grid.Column="1" Margin="5" ItemsSource="{Binding Executors}"
                  DisplayMemberPath="FullName" SelectedValuePath="Id" SelectedValue="{Binding AssignedToUserId}"/>

        <Label Grid.Row="7" Grid.Column="0" Content="Дата завершения:"/>
        <DatePicker Grid.Row="7" Grid.Column="1" Margin="5" SelectedDate="{Binding CompletionDate}"/>

        <Label Grid.Row="8" Grid.Column="0" Content="Комментарий:"/>
        <TextBox Grid.Row="8" Grid.Column="1" Margin="5" Text="{Binding RepairComment}" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Margin="5" Width="80"/>
            <Button Content="Отмена" Click="CancelButton_Click" Margin="5" Width="80"/>
        </StackPanel>
    </Grid>
</Window>