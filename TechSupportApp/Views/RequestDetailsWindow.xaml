<Window x:Class="TechSupportApp.Views.RequestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали заявки" Height="500" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Номер:"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding Request.Id}"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Дата создания:"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding Request.CreateDate, StringFormat=dd.MM.yyyy HH:mm}"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Клиент:"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Margin="5" Text="{Binding Request.ClientName}"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Телефон:"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Margin="5" Text="{Binding Request.ClientPhone}"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Тип техники:"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Margin="5" Text="{Binding Request.EquipmentType.Name}"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Описание:"/>
        <TextBlock Grid.Row="5" Grid.Column="1" Margin="5" Text="{Binding Request.Description}" TextWrapping="Wrap"/>

        <Label Grid.Row="6" Grid.Column="0" Content="Приоритет:"/>
        <TextBlock Grid.Row="6" Grid.Column="1" Margin="5" Text="{Binding Request.Priority.Name}"/>

        <Label Grid.Row="7" Grid.Column="0" Content="Статус:"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="{Binding Request.Status.Name}" VerticalAlignment="Center" Margin="5"/>
            <Button Content="Изменить статус" Command="{Binding ChangeStatusCommand}" Visibility="{Binding CanChangeStatus, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>

        <Label Grid.Row="8" Grid.Column="0" Content="Исполнитель:"/>
        <TextBlock Grid.Row="8" Grid.Column="1" Margin="5" Text="{Binding Request.AssignedToUser.FullName}"/>

        <Label Grid.Row="9" Grid.Column="0" Content="Дата завершения:"/>
        <TextBlock Grid.Row="9" Grid.Column="1" Margin="5" Text="{Binding Request.CompletionDate, StringFormat=dd.MM.yyyy}"/>

        <Label Grid.Row="10" Grid.Column="0" Content="Комментарий:"/>
        <TextBlock Grid.Row="10" Grid.Column="1" Margin="5" Text="{Binding Request.RepairComment}" TextWrapping="Wrap"/>
    </Grid>
</Window>