<Window x:Class="TechSupportApp.Views.Admin.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление пользователями" Height="500" Width="700" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <GroupBox Header="Добавление пользователя" Margin="5">
            <StackPanel Orientation="Horizontal">
                <Label Content="Логин:"/>
                <TextBox Text="{Binding NewLogin}" Width="100" Margin="5"/>
                <Label Content="Пароль:"/>
                <PasswordBox Name="PasswordBox" Width="100" Margin="5"/>
                <Label Content="ФИО:"/>
                <TextBox Text="{Binding NewFullName}" Width="150" Margin="5"/>
                <Label Content="Телефон:"/>
                <TextBox Text="{Binding NewPhone}" Width="100" Margin="5"/>
                <Label Content="Роль:"/>
                <ComboBox ItemsSource="{Binding Roles}" DisplayMemberPath="Name" SelectedValuePath="Id"
                          SelectedValue="{Binding NewRoleId}" Width="100" Margin="5"/>
                <Button Content="Добавить" Command="{Binding AddUserCommand}" Margin="5"/>
            </StackPanel>
        </GroupBox>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" AutoGenerateColumns="False"
                  SelectedItem="{Binding SelectedUser}" Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Редактировать" Command="{Binding EditUserCommand}" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteUserCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>